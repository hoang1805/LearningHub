# ==============================================================
# LearningHub — environment template
# Copy to the repo root as `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real secrets.
# Consumed by: infra/docker-compose.yml, Spring Boot
# (spring.config.import=optional:file:.env[.properties]), ai-server
# ==============================================================

# --- App ---
CLIENT_URL=http://localhost:5175

# --- PostgreSQL ---
POSTGRES_DB=learning_hub
POSTGRES_USER=learninghub
POSTGRES_PASSWORD=change-me
DB_URL=jdbc:postgresql://localhost:5432/learning_hub
DB_USER=learninghub
DB_PASSWORD=change-me

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/learning_hub

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Solr (standalone; tag + system-log search) ---
SOLR_HOST=http://localhost:8983/solr

# --- RabbitMQ (AMQP + STOMP relay) ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_STOMP_PORT=61613
RABBITMQ_USER=learninghub
RABBITMQ_PASS=change-me

# --- JWT (generate: openssl rand -base64 64) ---
JWT_SECRET=change-me-generate-a-long-random-secret
JWT_ACCESS_EXPIRE=1h
JWT_REFRESH_EXPIRE=120d

# --- MinIO (S3-compatible file storage) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=learninghub
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=learninghub

# --- Mail (dev: MailHog; prod: Brevo SMTP — swap values only) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@learninghub.local

# --- AI server ---
AI_SERVER_URL=http://localhost:8000
# shared secret for HMAC-signed grading callbacks (generate: openssl rand -hex 32)
AI_CALLBACK_SECRET=change-me-generate-a-random-hex-secret
AI_MAX_RETRIES=3

# --- Ollama (existing WSL install; Cloud models via OLLAMA_API_KEY from ollama.com) ---
# WSL2 forwards localhost:11434; from inside a container use http://host.docker.internal:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=change-me
# default grading/chatbot model (-cloud runs on ollama.com hardware);
# use a small local model (e.g. qwen2.5:7b) as offline fallback
AI_MODEL=gpt-oss:120b-cloud

# --- Judge0 (code execution sandbox) ---
JUDGE0_URL=http://localhost:2358
GRADING_MAX_RETRIES=3
